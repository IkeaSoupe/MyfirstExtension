{
  "manifest_version": 3,
  "name": "Smartschool Customizer",
  "version": "1.0",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://*.smartschool.be/*"],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "content_scripts": [
    {
      "matches": ["*://*.smartschool.be/*"],
      "js": ["content.js"]
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "data_collection_permissions": {
    "user_data": []
  }
}